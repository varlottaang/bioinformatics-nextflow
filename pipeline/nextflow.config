--- /home/user/nextflow-cancer-genomics-90min/pipeline/nextflow.config
++ /home/user/nextflow-cancer-genomics-90min/pipeline/nextflow.config
@@ -0,0 +1,71 @@
/*
 * Nextflow Cancer Genomics — Pipeline Configuration
 *
 * This config is tuned for GitHub Codespaces (2 CPU, 4 GB RAM).
 * The test profile uses chr17-only data that completes in ~5 minutes.
 */

// ─── Default process settings ───────────────────────────────────────────────

process {
    cpus   = 1
    memory = '1.GB'
    time   = '30.min'
}

// ─── Profiles ───────────────────────────────────────────────────────────────

profiles {

    docker {
        docker.enabled = true
        docker.runOptions = '--platform linux/amd64'
    }

    test {
        params {
            samplesheet        = "${projectDir}/../data/samplesheet.csv"
            salmon_index       = "${projectDir}/../data/reference/salmon_index"
            transcript_to_gene = "${projectDir}/../data/reference/tx2gene.tsv"
            outdir             = "${projectDir}/../results"
        }
        process {
            cpus   = 1
            memory = '1.GB'
        }
    }

    // For machines with more resources
    standard {
        process {
            cpus   = 2
            memory = '2.GB'
        }
    }
}

// ─── Execution reports ──────────────────────────────────────────────────────

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}

// ─── Manifest ───────────────────────────────────────────────────────────────

manifest {
    name            = 'nextflow-cancer-genomics-90min'
    author          = 'Course Instructor'
    description     = 'RNA-seq differential expression pipeline for teaching'
    version         = '1.0.0'
    nextflowVersion = '!>=25.04.0'
    mainScript      = 'main.nf'
}